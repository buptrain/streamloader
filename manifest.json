{
  "manifest_version": 3,
  "name": "StreamLoader",
  "version": "0.1.0",
  "description": "List all MP4 streams detected on the current webpage.",
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "webNavigation",
    "sidePanel",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "StreamLoader"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
